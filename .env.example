# Sanity (CMS for projects, books, notes, likes, work, uses, about copy)
# Get these from https://www.sanity.io/manage after creating a project
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Hashnode (blog source — public posts only, no API key needed)
# Your publication host, e.g. seungwaakpan.hashnode.dev
PUBLIC_HASHNODE_HOST=

# Strava (build-time fetch for /miles)
# 1. Create an app at https://www.strava.com/settings/api
# 2. Run the one-time OAuth flow to get a refresh token (instructions in README)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=
STRAVA_ATHLETE_ID=
